ENV=dev
DEBUG=true
LOG_LEVEL=INFO

APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
DATABASE_URL=sqlite:///./database.db

JWT_SECRET=replace-with-a-random-local-secret
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_MINUTES=1440

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

HUGGINGCHAT_PROXY_URL=http://ml-proxy:8001
HF_TOKEN=
HF_MODEL=
HF_MODEL_CANDIDATES=
HF_API_URL=

GIGA_CLIENT_ID=
GIGA_CLIENT_SECRET=
GIGA_SCOPE=GIGACHAT_API_PERS

# Docker Compose uses these values to create its local PostgreSQL service.
POSTGRES_USER=ciuser
POSTGRES_PASSWORD=replace-with-a-random-local-password
POSTGRES_DB=cidb
